{
  "name": "india-tax-rules-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @elevate/india-tax-rules and companion packages.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "test": "pnpm -r --filter=./packages/* test",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "lint": "pnpm -r --filter=./packages/* lint",
    "lint:fix": "pnpm -r --filter=./packages/* lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "packages/core/**/*.{ts,tsx}": [
      "pnpm -C packages/core exec eslint --max-warnings 0 --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.4"
  }
}
